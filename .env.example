# ── Database (Supabase) ─────────────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection string
# Use the Session pooler URI (port 6543)
DATABASE_URL=postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Payload ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=a-long-random-string-at-least-32-chars

# ── Cloudflare R2 Media Storage ────────────────────────────────────
# Bucket name (e.g. portfolio-media)
CLOUDFLARE_R2_BUCKET=portfolio-media

# R2 endpoint URL (without the bucket path, e.g. https://abc123.r2.cloudflarestorage.com)
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# R2 API Token credentials (Manage R2 API Tokens → create with Object Read & Write)
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key

# Public URL for serving media (r2.dev subdomain or custom domain)
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ── Site ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
